<?xml version="1.0" encoding="utf-8"?>
   <Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
      <!-- COPY THIS FILE AS 'APLC.csproj.user' AND EDIT THESE SETTINGS -->
      <PropertyGroup>
         <!-- Set this to the folder that contains 'Lethal Company.exe' -->
         <GameDirectory>C:\Program Files (x86)\Steam\steamapps\common\Lethal Company\</GameDirectory>

         <!-- Set this to the location you want the mod files copied to for testing (usually a profile in a mod manager) -->
         <ModTestDirectory></ModTestDirectory>
      </PropertyGroup>

      <!-- Do Not Modify -->
      <PropertyGroup>
         <ManagedDirectory>$(GameDirectory)Lethal Company_Data/Managed/</ManagedDirectory>
         <ThunderstoreDirectory>$(ProjectDir)Thunderstore\</ThunderstoreDirectory>
      </PropertyGroup>

      <!-- Copies mod files to a profile for testing. Will do nothing if ModTestDirectory is left blank. -->
      <Target Name="MoveDllToMods" AfterTargets="Build" Condition="Exists('$(TargetDir)$(TargetName).dll') And Exists('$(ModTestDirectory)/') And $(ConfigurationName) == Release">
         <Message Text="Copying $(ProjectName).dll to $(ModTestDirectory) Folder..." Importance="high" />
         <Delete Condition="Exists('$(ModTestDirectory)\$(ProjectName).dll')" Files="$(ModTestDirectory)\$(ProjectName).dll" />
         <Delete Condition="Exists('$(ModTestDirectory)\Archipelago.MultiClient.Net.dll')" Files="$(ModTestDirectory)\Archipelago.MultiClient.Net.dll" />
         <Copy SourceFiles="$(TargetDir)$(TargetName).dll" DestinationFiles="$(ModTestDirectory)\$(ProjectName).dll" />
         <Copy SourceFiles="$(PkgArchipelago_MultiClient_Net)\lib\netstandard2.0\Archipelago.MultiClient.Net.dll" DestinationFiles="$(ModTestDirectory)\Archipelago.MultiClient.Net.dll" />
      </Target>
   </Project>
